* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  min-height: 100vh;
  font-family: Arial, sans-serif;
  color: #fff1e7;
  background:
    radial-gradient(circle at top left, rgba(205, 115, 65, 0.45), transparent 35%),
    radial-gradient(circle at bottom right, rgba(120, 62, 38, 0.7), transparent 40%),
    linear-gradient(135deg, #180d0a 0%, #3b1e16 45%, #130907 100%);
}

.page {
  width: min(1180px, 94%);
  margin: auto;
  padding: 22px 0 40px;
}

.glass {
  background: rgba(255, 235, 220, 0.08);
  border: 1px solid rgba(255, 229, 210, 0.18);
  backdrop-filter: blur(22px);
  -webkit-backdrop-filter: blur(22px);
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
}

.nav {
  position: sticky;
  top: 18px;
  z-index: 20;
  border-radius: 28px;
  padding: 16px 22px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand span {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(226, 139, 92, 0.22);
  display: grid;
  place-items: center;
  color: #f0a77f;
  font-size: 24px;
}

.brand h1,
.footer h2 {
  font-family: Georgia, serif;
  letter-spacing: 7px;
  font-size: 23px;
}

.brand p,
.footer p {
  color: #e8b491;
  font-style: italic;
  font-size: 14px;
}

nav {
  display: flex;
  gap: 28px;
}

nav a {
  color: #f7d9c7;
  text-decoration: none;
  font-size: 15px;
}

.nav-btn,
.actions a,
.cta a {
  text-decoration: none;
  color: white;
  background: linear-gradient(135deg, #d87b43, #9f4729);
  padding: 13px 22px;
  border-radius: 18px;
  font-weight: 700;
}

.hero {
  min-height: 690px;
  display: grid;
  grid-template-columns: 1fr 1.05fr;
  align-items: center;
  gap: 42px;
  padding: 60px 0 35px;
}

.hero-text {
  border-radius: 38px;
  padding: 54px;
}

.small {
  color: #f0a77f;
  font-size: 13px;
  letter-spacing: 2px;
  font-weight: 700;
}

.hero h2,
.section-title h2,
.cta h2 {
  font-family: Georgia, serif;
  font-size: 64px;
  line-height: 1.03;
  margin: 20px 0;
}

.desc {
  max-width: 520px;
  color: #f0d0bd;
  line-height: 1.8;
  font-size: 17px;
}

.actions {
  margin-top: 32px;
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.actions .secondary {
  background: transparent;
  border: 1px solid rgba(255, 229, 210, 0.35);
}

.hero-photo {
  position: relative;
}

.hero-photo img {
  width: 100%;
  height: 610px;
  object-fit: cover;
  border-radius: 42px;
  box-shadow: 0 35px 90px rgba(0, 0, 0, 0.55);
}

.floating {
  position: absolute;
  left: -28px;
  bottom: 45px;
  border-radius: 24px;
  padding: 20px 26px;
}

.floating strong {
  display: block;
  font-family: Georgia, serif;
  font-size: 24px;
}

.floating span {
  color: #ecc8b4;
}

.services {
  padding: 30px 0;
}

.section-title {
  text-align: center;
  margin-bottom: 30px;
}

.section-title h2 {
  font-size: 46px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 22px;
}

.card {
  border-radius: 30px;
  padding: 14px;
  overflow: hidden;
}

.card img {
  width: 100%;
  height: 210px;
  object-fit: cover;
  border-radius: 22px;
}

.card h3 {
  font-family: Georgia, serif;
  font-size: 24px;
  margin: 18px 8px 10px;
}

.card p {
  color: #ebcaba;
  line-height: 1.6;
  margin: 0 8px 10px;
  font-size: 15px;
}

.details {
  margin-top: 28px;
  border-radius: 34px;
  padding: 30px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

.details div {
  text-align: center;
  padding: 20px;
}

.details span {
  font-size: 36px;
}

.details h3 {
  font-family: Georgia, serif;
  font-size: 25px;
  margin: 14px 0 8px;
}

.details p {
  color: #eac8b4;
  line-height: 1.6;
}

.cta {
  margin-top: 28px;
  border-radius: 36px;
  padding: 38px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 30px;
}

.cta h2 {
  font-size: 42px;
}

.footer {
  text-align: center;
  padding: 44px 0 10px;
}

@media (max-width: 950px) {
  .nav {
    align-items: flex-start;
    gap: 18px;
    flex-direction: column;
  }

  nav {
    flex-wrap: wrap;
    gap: 16px;
  }

  .hero {
    grid-template-columns: 1fr;
    padding-top: 35px;
  }

  .hero-text {
    padding: 34px;
  }

  .hero h2 {
    font-size: 44px;
  }

  .hero-photo img {
    height: 430px;
  }

  .floating {
    left: 18px;
    bottom: 18px;
  }

  .grid,
  .details {
    grid-template-columns: 1fr;
  }

  .cta {
    flex-direction: column;
    align-items: flex-start;
  }

  .cta h2,
  .section-title h2 {
    font-size: 34px;
  }
}